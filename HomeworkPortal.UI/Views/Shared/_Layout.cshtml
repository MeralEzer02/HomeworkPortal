@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using System.Text
@inject IHttpContextAccessor HttpContextAccessor

@{
    var token = HttpContextAccessor.HttpContext?.Session.GetString("Token");
    var userRole = "";
    var userEmail = "Kullanıcı";

    var currentPath = HttpContextAccessor.HttpContext?.Request.Path.Value?.ToLower() ?? "";

    if (!string.IsNullOrEmpty(token))
    {
        try
        {
            var payload = token.Split('.')[1];
            payload = payload.Replace('-', '+').Replace('_', '/');
            payload = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=');

            var bytes = Convert.FromBase64String(payload);
            var json = Encoding.UTF8.GetString(bytes);
            var parsed = JsonSerializer.Deserialize<JsonElement>(json);

            if (parsed.TryGetProperty("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", out var roleProp))
                userRole = roleProp.GetString() ?? "";
            else if (parsed.TryGetProperty("role", out roleProp))
                userRole = roleProp.GetString() ?? "";

            if (parsed.TryGetProperty("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress", out var emailProp))
                userEmail = emailProp.GetString() ?? "Kullanıcı";
            else if (parsed.TryGetProperty("email", out emailProp))
                userEmail = emailProp.GetString() ?? "Kullanıcı";
        }
        catch { }
    }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>HomeworkPortal - Admin</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link href="~/AdminTheme/img/favicon.ico" rel="icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/AdminTheme/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/AdminTheme/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />
    <link href="~/AdminTheme/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/AdminTheme/css/style.css" rel="stylesheet">

    <style>
        /* YENİ NESİL SİDEBAR TASARIMI */
        .sidebar {
            width: 210px !important;
            padding-right: 0 !important; /* O sinir bozucu sağ boşluğu yokediyoruz */
            padding-bottom: 0 !important; /* Alt boşluğu yokediyoruz */
            background-color: #F3F6F9 !important; /* Gri rengi kök elemana veriyoruz ki tam yayılsın */
        }

            .sidebar .navbar {
                background-color: transparent !important; /* İçteki nav'ın arka planını şeffaf yapıyoruz */
            }

        .content {
            margin-left: 210px !important;
            width: calc(100% - 210px) !important;
        }

        @@media (max-width: 991.98px) {
            .sidebar

        {
            transform: translateX(-210px);
        }

        .content {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .sidebar.open {
            transform: translateX(0);
        }

        }

        .custom-logo {
            font-size: 1.4rem;
            line-height: 1.2;
            margin-bottom: 0;
            display: inline-block;
        }

            .custom-logo i {
                vertical-align: middle;
                margin-bottom: 5px;
            }
    </style>
</head>

<body>
    <div class="container-xxl position-relative bg-white d-flex p-0">
        <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="sr-only">Yükleniyor...</span>
            </div>
        </div>

        <div class="sidebar">
            <nav class="navbar navbar-light">

                <a href="/" class="navbar-brand mx-4 mb-3 mt-2">
                    <h3 class="text-primary custom-logo">
                        <i class="fa fa-graduation-cap me-2"></i>Homework<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Portal
                    </h3>
                </a>

                <div class="d-flex align-items-center ms-4 mb-4 mt-2">
                    <div class="position-relative">
                        <img class="rounded-circle" src="~/AdminTheme/img/user.jpg" alt="" style="width: 40px; height: 40px;">
                        <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0">@userEmail.Split('@')[0]</h6>
                        <span>@userRole</span>
                    </div>
                </div>

                <div class="navbar-nav w-100 mt-2">
                    <a href="/Home/Index" class="nav-item nav-link @(currentPath == "/" || currentPath.Contains("/home") ? "active" : "")">
                        <i class="fa fa-tachometer-alt me-2"></i>Dashboard
                    </a>

                    <a href="/Courses" class="nav-item nav-link @(currentPath.Contains("/courses") ? "active" : "")">
                        <i class="fa fa-book me-2"></i>Kurslar
                    </a>

                    @if (userRole == "Teacher" || userRole == "Student" || userRole == "Admin")
                    {
                        <a href="/Assignments" class="nav-item nav-link @(currentPath.Contains("/assignments") ? "active" : "")">
                            <i class="fa fa-tasks me-2"></i>Ödevler
                        </a>
                    }

                    @if (userRole == "Teacher" || userRole == "Student")
                    {
                        <a href="/Submissions" class="nav-item nav-link @(currentPath.Contains("/submissions") ? "active" : "")">
                            <i class="fa fa-check-square me-2"></i>Teslimler
                        </a>
                    }
                </div>
            </nav>
        </div>

        <div class="content">
            <nav class="navbar navbar-expand bg-light navbar-light sticky-top px-4 py-0">
                <a href="/" class="navbar-brand d-flex d-lg-none me-4">
                    <h2 class="text-primary mb-0"><i class="fa fa-graduation-cap"></i></h2>
                </a>
                <a href="#" class="sidebar-toggler flex-shrink-0">
                    <i class="fa fa-bars"></i>
                </a>
                <div class="navbar-nav align-items-center ms-auto">
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <img class="rounded-circle me-lg-2" src="~/AdminTheme/img/user.jpg" alt="" style="width: 40px; height: 40px;">
                            <span class="d-none d-lg-inline-flex">@userEmail.Split('@')[0]</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end bg-light border-0 rounded-0 rounded-bottom m-0">
                            <a href="/Profile" class="dropdown-item">Profilim</a>
                            <hr class="dropdown-divider">
                            <a href="/Auth/Logout" class="dropdown-item text-danger">Çıkış Yap</a>
                        </div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid pt-4 px-4">
                @RenderBody()
            </div>

            <div class="container-fluid pt-4 px-4 mt-auto">
                <div class="bg-light rounded-top p-4">
                    <div class="row">
                        <div class="col-12 col-sm-6 text-center text-sm-start">
                            &copy; <a href="#">HomeworkPortal</a>, Tüm Hakları Saklıdır.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/AdminTheme/lib/chart/chart.min.js"></script>
    <script src="~/AdminTheme/lib/easing/easing.min.js"></script>
    <script src="~/AdminTheme/lib/waypoints/waypoints.min.js"></script>
    <script src="~/AdminTheme/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/AdminTheme/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/AdminTheme/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/AdminTheme/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>

    <script src="~/AdminTheme/js/main.js"></script>

    <script>
        var jwtToken = "@Html.Raw(token)";

        $.ajaxPrefilter(function (options, originalOptions, jqXHR) {
            if (jwtToken && options.url.includes("7113")) {
                jqXHR.setRequestHeader('Authorization', 'Bearer ' + jwtToken);
            }
        });

        $(document).ajaxError(function (event, xhr, settings) {
            if (settings.url.includes("7113")) {
                if (xhr.status === 401) {
                    alert("Oturum süreniz doldu veya geçersiz. Lütfen tekrar giriş yapın.");
                    window.location.href = "/Auth/Login";
                } else if (xhr.status === 403) {
                    alert("Bu işlemi gerçekleştirmek için yetkiniz bulunmamaktadır.");
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>